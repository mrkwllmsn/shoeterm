# --------------------------------------------------------------------------- #
#  graphics-capable terminal detection
# --------------------------------------------------------------------------- #
def text_mode():
    """SHOEMAC_PIXELFONT → "pixel" / "pixel <scale>" for the bitmap font, else None."""
    v = os.environ.get("SHOEMAC_PIXELFONT")
    if not v or v == "0":
        return None
    try:
        scale = int(v)
    except ValueError:
        scale = 1
    return "pixel %d" % scale if scale > 1 else "pixel"


def graphics_ok():
    if os.environ.get("SHOEMAC_PLAIN"):
        return False
    if os.environ.get("SHOEMAC_FORCE"):
        return True
    if not sys.stdout.isatty():
        return False
    term = os.environ.get("TERM", "")
    return "foot" in term or "ghostty" in term


# --------------------------------------------------------------------------- #
#  app registry
# --------------------------------------------------------------------------- #
#  Built-in chrome (menu bar, Dock, windows) is theme code below; the only
#  built-in "app" is the decorative Trash window.  Every real app lives in its
#  own shoemac_<name>.py module and registers here via make_app() -> spec dict.
#  An app spec is a dict; see "the contract" near _load_apps() for the keys.
# --------------------------------------------------------------------------- #
WIN_SIZE = {
    "trash": (380, 240),     # built-in decorative Trash window
}
WIN_TITLE = {
    "trash": "Trash",
}

APP_DRAW = {}     # kind -> draw(cv, d, win)
APP_CLICK = {}    # kind -> click(win, px, py, d, btn) -> bool
APP_MOUSE = {}    # kind -> mouse(win, phase, px, py, d, btn)  (drag-aware apps)
APP_KEY = {}      # kind -> key(win, key, d) -> bool
APP_WHEEL = {}    # kind -> wheel(win, px, py, up, d) -> bool
APP_ICON16 = {}   # kind -> icon16(cv, x, y)            (optional, unused by chrome)
APP_ICON48 = {}   # kind -> icon48(cv, cx, top)         (Dock / desktop icon)
APP_INIT = {}     # kind -> init(win)                   (set win.state / win.pane)


def register_app(spec):
    k = spec["kind"]
    WIN_SIZE[k] = tuple(spec["size"])
    WIN_TITLE[k] = spec["title"]
    APP_DRAW[k] = spec["draw"]
    if spec.get("click"):
        APP_CLICK[k] = spec["click"]
    if spec.get("mouse"):
        APP_MOUSE[k] = spec["mouse"]
    if spec.get("key"):
        APP_KEY[k] = spec["key"]
    if spec.get("wheel"):
        APP_WHEEL[k] = spec["wheel"]
    if spec.get("init"):
        APP_INIT[k] = spec["init"]
    if spec.get("icon16"):
        APP_ICON16[k] = spec["icon16"]
    if spec.get("icon48"):
        APP_ICON48[k] = spec["icon48"]
    # placement: a truthy "dock" (or legacy "start") flag puts the app on the
    # Dock, between Finder and the separator+Trash; a truthy "desktop" flag
    # adds a desktop icon (top-right column).
    if spec.get("dock") or spec.get("start"):
        if k not in DOCK_ITEMS:
            DOCK_ITEMS.append(k)
    if spec.get("desktop"):
        DESK_ICONS.append((k, spec.get("desktop_label", spec["title"])))


def _load_apps():
    import importlib
    for name in ("shoemac_finder", "shoemac_calc",
                 "shoemac_about", "shoemac_safari", "shoemac_terminal"):
        try:
            register_app(importlib.import_module(name).make_app())
        except Exception as e:                       # noqa: BLE001
            sys.stderr.write("shoemac: skipping %s: %s\n" % (name, e))


# --------------------------------------------------------------------------- #
#  windows
# --------------------------------------------------------------------------- #
class Win:
    _seq = 0

    def __init__(self, kind, x, y, path=None):
        Win._seq += 1
        self.id = Win._seq
        self.kind = kind
        self.x, self.y = x, y
        self.w, self.h = WIN_SIZE[kind]
        self.title = WIN_TITLE[kind]
        self.minimized = False
        self.zoomed = False          # maximised? (zoom traffic light / Window menu)
        self.restore = None          # saved (x, y, w, h) to un-zoom back to
        self.open_path = path        # apps that browse a path read this in init
        self.state = {}
        if kind in APP_INIT:
            APP_INIT[kind](self)

    # window-local geometry helpers ----------------------------------------
    @property
    def title_h(self):
        return 22

    def body_rect(self):
        return (self.x + 3, self.y + self.title_h,
                self.w - 6, self.h - self.title_h - 4)

    def contains(self, px, py):
        return self.x <= px < self.x + self.w and self.y <= py < self.y + self.h

    def in_title(self, px, py):
        return (self.x <= px < self.x + self.w and
                self.y <= py < self.y + self.title_h)


# --------------------------------------------------------------------------- #
#  desktop icons (top-right column) and Dock contents
# --------------------------------------------------------------------------- #
DESK_ICONS = [
    ("machd", "Macintosh HD"),
]
ICON_W, ICON_H = 86, 72

# the Dock holds Finder first, then any app with a truthy "dock" flag, then a
# separator and the Trash (always last).  register_app() appends to this list.
DOCK_ITEMS = ["finder"]


# --------------------------------------------------------------------------- #
#  the desktop / window manager
# --------------------------------------------------------------------------- #
class Desktop:
    def __init__(self, W, H, cw, ch):
        self.W, self.H, self.cw, self.ch = W, H, cw, ch
        self.charw = max(5, cw)
        self.menubar_h = 24
        self.wins = []                 # z-order: last is topmost
        self.icon_sel = -1
        self.cascade = 0
        self.dock_hover_x = None       # last pointer x over the Dock (or None)
        self.open_menu = None          # currently-dropped menu id, or None
        self.menu_sel = -1             # hovered item index in the open menu
        self.user = os.environ.get("USER") or os.environ.get("USERNAME") or "user"
        try:
            self.host = socket.gethostname()
        except OSError:
            self.host = "localhost"

    # ----- desktop icon hit boxes (top-right column) ----------------------
    def icon_rect(self, i):
        x = self.W - ICON_W - 16
        y = self.menubar_h + 12 + i * (ICON_H + 8)
        return (x, y, ICON_W, ICON_H)

    def icon_at(self, px, py):
        for i in range(len(DESK_ICONS)):
            x, y, w, h = self.icon_rect(i)
            if x <= px < x + w and y <= py < y + h:
                return i
        return None

    # ----- Dock geometry --------------------------------------------------
    def dock_entries(self):
        # ("app", kind) tiles, a ("sep", None) divider, then the Trash tile
        return ([("app", k) for k in DOCK_ITEMS] +
                [("sep", None), ("app", "trash")])

    def dock_shelf_rect(self):
        items = self.dock_entries()
        B, G, SEPW = 40, 10, 12
        base_w = [SEPW if t == "sep" else B for (t, _) in items]
        total = sum(base_w) + G * (len(items) - 1)
        x0 = (self.W - total) // 2
        shelf_w = total + 24
        shelf_h = B + 18
        shelf_y = self.H - shelf_h - 6
        return (x0 - 12, shelf_y, shelf_w, shelf_h)

    def dock_layout(self, hover_x=None):
        # Returns [(type, kind, x, y, w, h), ...].  Tiles are square; the tile
        # nearest hover_x (and, lightly, its neighbours) magnifies.  Scales are
        # computed from the resting centres, then the magnified tiles are laid
        # out centred and bottom-aligned on the shelf.
        items = self.dock_entries()
        B, DMAX, G, SEPW, INF = 40, 60, 10, 12, 80
        base_w = [SEPW if t == "sep" else B for (t, _) in items]
        total_base = sum(base_w) + G * (len(items) - 1)
        x0 = (self.W - total_base) // 2
        centers = []
        cx = x0
        for w in base_w:
            centers.append(cx + w / 2)
            cx += w + G
        sw = []
        for (t, _), c, bw in zip(items, centers, base_w):
            if t == "sep" or hover_x is None:
                sw.append(bw)
                continue
            dist = abs(hover_x - c)
            boost = max(0.0, 1.0 - dist / INF)
            sw.append(int(B + (DMAX - B) * boost))
        total = sum(sw) + G * (len(items) - 1)
        sx = (self.W - total) // 2
        _shx, shy, _shw, shh = self.dock_shelf_rect()
        base_y = shy + shh - 9          # tiles sit on the shelf, grow upward
        rects = []
        x = sx
        for (t, payload), w in zip(items, sw):
            h = w
            rects.append((t, payload, x, base_y - h, w, h))
            x += w + G
        return rects

    def dock_hit(self, px, py):
        # Compute the layout magnified at the click x, so the tile under the
        # cursor is the big one and the point lands inside it.
        for (t, kind, x, y, w, h) in self.dock_layout(px):
            if t == "sep":
                continue
            if x <= px < x + w and y <= py < y + h:
                return kind
        return None

    def in_dock_zone(self, py):
        _x, y, _w, h = self.dock_shelf_rect()
        return py >= y - 24          # include the magnified overhang above

    # ----- window management ----------------------------------------------
    def focus(self, win):
        if win in self.wins and self.wins[-1] is not win:
            self.wins.remove(win)
            self.wins.append(win)
        win.minimized = False

    def top_win(self):
        for w in reversed(self.wins):
            if not w.minimized:
                return w
        return None

    def win_at(self, px, py):
        for w in reversed(self.wins):
            if not w.minimized and w.contains(px, py):
                return w
        return None

    def open_app(self, kind, path=None):
        if kind not in WIN_SIZE:
            return None               # app module not loaded; ignore quietly
        # focus an existing window of this kind unless it's the Finder (which
        # can have several, e.g. one window per folder)
        if kind != "finder":
            for w in self.wins:
                if w.kind == kind:
                    self.focus(w)
                    return w
        x = 90 + (self.cascade % 6) * 28
        y = self.menubar_h + 24 + (self.cascade % 6) * 24
        self.cascade += 1
        win = Win(kind, x, y, path)
        self.wins.append(win)
        return win

    def close(self, win):
        if win in self.wins:
            self.wins.remove(win)

    # ----- zoom / maximise ------------------------------------------------
    def zoom_rect(self):
        """The maximised window rectangle: fill the desktop between the menu
        bar and the Dock shelf, with a small margin."""
        m = 6
        _sx, sy, _sw, _sh = self.dock_shelf_rect()
        top = self.menubar_h + m
        bottom = sy - 8                       # clear the Dock's magnified overhang
        return (m, top, self.W - 2 * m, max(140, bottom - top))

    def toggle_zoom(self, win):
        if win.zoomed and win.restore:
            win.x, win.y, win.w, win.h = win.restore
            win.zoomed = False
            win.restore = None
        else:
            win.restore = (win.x, win.y, win.w, win.h)
            win.x, win.y, win.w, win.h = self.zoom_rect()
            win.zoomed = True

    def refit_zoomed(self):
        """Re-maximise any zoomed window after a resize."""
        for w in self.wins:
            if w.zoomed:
                w.x, w.y, w.w, w.h = self.zoom_rect()

    # ----- menu bar -------------------------------------------------------
    def menubar_hit(self, px):
        """Which menu id sits under px on the menu bar (or None)."""
        apple, items, _name = menubar_layout(self)
        ax, _ay, aw, _ah = apple
        if ax <= px < ax + aw:
            return "apple"
        for (mid, label, x) in items:
            rx, _ry, rw, _rh = menu_item_rect(self, x, label)
            if rx <= px < rx + rw:
                return mid
        return None


