#  rendering
# =========================================================================== #
def draw_wallpaper(cv, d):
    W, H = d.W, d.H
    # --- richer multi-stop night sky ------------------------------------- #
    # indigo -> deep violet -> aurora-lit violet -> cool blue -> dark bottom
    cv.vgrad(0, 0,            W, int(H * 0.28), C["wp0"], C["wp1"], 22)
    cv.vgrad(0, int(H*0.28),  W, int(H * 0.22), C["wp1"], C["wp2"], 18)
    cv.vgrad(0, int(H*0.50),  W, int(H * 0.28), C["wp2"], C["wp3"], 18)
    cv.vgrad(0, int(H*0.78),  W, H - int(H*0.78), C["wp3"], C["wp4"], 14)

    # --- starfield: varied brightness, a few warm + a couple of bright ---- #
    rng = [1234567]
    def nxt():
        rng[0] = (rng[0] * 1103515245 + 12345) & 0x7fffffff
        return rng[0]
    for _ in range(70):
        sx = nxt() % W
        sy = nxt() % int(H * 0.55)
        tier = nxt() % 100
        if tier < 6:                       # rare bright star with a tiny glow
            cv.pen(_a(C["star"], 0x33)); cv.rectf(sx - 1, sy, 3, 1)
            cv.rectf(sx, sy - 1, 1, 3)
            cv.pen(C["star"]);            cv.rectf(sx, sy, 1, 1)
        elif tier < 16:                    # warm-tinted star
            cv.pen(_a(C["starwarm"], 0xcc)); cv.rectf(sx, sy, 1, 1)
        else:                              # faint dust, alpha by tier
            a = 0x44 + (tier % 7) * 0x18
            cv.pen(_a(C["star"], min(a, 0xdd))); cv.rectf(sx, sy, 1, 1)

    # --- the aurora: two overlapping curtains (glow bands + striations) --- #
    _aurora(cv, W, H, int(H * 0.34), 0.9, 0.0)
    _aurora(cv, W, H, int(H * 0.26), 0.6, 2.3)


def _a(rgb, alpha):
    """#rrggbb + alpha int -> #rrggbbaa (rgb may already carry alpha)."""
    return rgb[:7] + ("%02x" % max(0, min(255, alpha)))


def _wave(t, ymid, amp, ph):
    # smooth baseline: two sines at different frequencies
    return ymid + amp * math.sin(t * math.tau * 1.4 + ph) \
                + amp * 0.4 * math.sin(t * math.tau * 3.1 + ph * 1.7)


def _ripple(t, ph):
    # 0.30 .. 1.0 height profile so the curtain top folds tall and short
    s = 0.5 + 0.5 * math.sin(t * math.tau * 2.3 + ph * 0.8 + 1.1)
    s *= 0.6 + 0.4 * (0.5 + 0.5 * math.sin(t * math.tau * 5.7 + ph))
    return 0.30 + 0.70 * s


def _band(cv, W, ymid, amp, height, ph, col, alpha):
    """One smooth filled curtain layer rising from the baseline."""
    n = 72
    top, bot = [], []
    for i in range(n + 1):
        t = i / n
        x = W * i // n
        b = _wave(t, ymid, amp, ph)
        h = height * _ripple(t, ph)
        top.append((x, int(b - h)))
        bot.append((x, int(b)))
    pts = []
    for (x, y) in top:
        pts += [x, y]
    for (x, y) in reversed(bot):
        pts += [x, y]
    cv.pen(_a(col, alpha))
    cv.polyf(pts)


def _aurora(cv, W, H, ymid, scale, ph):
    amp = int(H * 0.045)
    h1 = int(H * 0.10 * scale)   # bright green base
    h2 = int(H * 0.20 * scale)   # teal mid
    h3 = int(H * 0.30 * scale)   # faint violet tips
    # diffuse glow: tallest+faintest first, brightest base last (source-over)
    _band(cv, W, ymid, amp, h3, ph, C["aurvio"], 0x12)
    _band(cv, W, ymid, amp, h2, ph, C["aurtea"], 0x20)
    _band(cv, W, ymid, amp, h1, ph, C["aurgrn"], 0x3a)
    # vertical striations give the curtain its texture
    ncol = 90
    seed = [987654 + int(ph * 1000)]
    def r():
        seed[0] = (seed[0] * 1103515245 + 12345) & 0x7fffffff
        return seed[0]
    cv.thickness(1)
    for k in range(ncol):
        t = (k + (r() % 100) / 140.0) / ncol
        if t > 1.0:
            t = 1.0
        x = int(W * t)
        b = _wave(t, ymid, amp, ph)
        h = h2 * _ripple(t, ph) * (0.55 + (r() % 100) / 220.0)
        a = 0x14 + (r() % 0x1c)
        cv.pen(_a(C["aurstr"], int(a * scale)))
        cv.rectf(x, int(b - h), 1, int(h))


def draw_desktop_icons(cv, d):
    for i, (kind, label) in enumerate(DESK_ICONS):
        x, y, w, h = d.icon_rect(i)
        if i == d.icon_sel:
            cv.pen(C["iconsel"])
            cv.rrectf(x, y, w, h, 6)
        cx = x + w // 2
        draw_big_icon(cv, kind, cx, y + 6)
        draw_label_centered(cv, d, cx, y + h - 12, label)


def draw_label_centered(cv, d, cx, ty, label):
    tw = len(label) * d.charw
    tx = cx - tw // 2
    tx = max(2, min(tx, d.W - tw - 2))
    cv.pen("#00000080")
    cv.text(tx + 1, ty + 1, label)
    cv.pen(C["iconlbl"])
    cv.text(tx, ty, label)


def draw_big_icon(cv, kind, cx, top):
    # ~48px icon centred on cx, starting at y=top
    if kind in APP_ICON48:
        APP_ICON48[kind](cv, cx, top)
        return
    if kind == "machd":
        draw_machd_icon(cv, cx, top)
    elif kind == "trash":
        draw_trash_icon(cv, cx, top)
    else:
        # generic rounded tile with the kind's initial
        cv.vgrad(cx - 20, top, 40, 40, "#dfe6ef", "#9fb0c4", 8)
        cv.pen("#7f8c9c"); cv.rrect(cx - 20, top, 40, 40, 8)
        ch = kind[:1].upper() if kind else "?"
        cv.pen("#3a4658"); cv.text(cx - 4, top + 27, ch)


def draw_machd_icon(cv, cx, top):
    # a brushed metal hard drive
    cv.pen(C["shadow"]); cv.rrectf(cx - 18, top + 6, 38, 30, 5)
    cv.vgrad(cx - 20, top + 4, 40, 30, "#f2f4f7", "#aab2bd", 8)
    cv.pen("#8a93a0"); cv.rrect(cx - 20, top + 4, 40, 30, 8)
    # face plate sheen
    cv.pen("#ffffff66"); cv.rectf(cx - 16, top + 7, 32, 2)
    # activity slot + dot
    cv.pen("#5a6472"); cv.rrectf(cx - 12, top + 24, 24, 4, 2)
    cv.pen("#2f9bdc"); cv.circf(cx + 13, top + 10, 2)


def draw_trash_icon(cv, cx, top):
    # a wire mesh trash can
    cv.pen(C["shadow"]); cv.rrectf(cx - 13, top + 12, 28, 26, 4)
    cv.vgrad(cx - 14, top + 10, 28, 26, "#d8dde4", "#aab2bd", 6)
    cv.pen("#8a93a0"); cv.rrect(cx - 14, top + 10, 28, 26, 4)
    # ribs
    cv.pen("#9aa3b0")
    for dx in (-7, 0, 7):
        cv.line(cx + dx, top + 13, cx + dx, top + 34)
    # lid + handle
    cv.pen("#9aa3b0"); cv.rrectf(cx - 17, top + 5, 34, 5, 2)
    cv.pen("#8a93a0"); cv.rrectf(cx - 5, top + 1, 10, 4, 2)


# ----- windows ------------------------------------------------------------- #
def light_centers(win):
    cy = win.y + win.title_h // 2
    return ((win.x + 16, cy), (win.x + 34, cy), (win.x + 52, cy))


def close_btn_rect(win):
    (cx, cy), _, _ = light_centers(win)
    return (cx - 8, cy - 8, 16, 16)


def min_btn_rect(win):
    _, (cx, cy), _ = light_centers(win)
    return (cx - 8, cy - 8, 16, 16)


def zoom_btn_rect(win):
    _, _, (cx, cy) = light_centers(win)
    return (cx - 8, cy - 8, 16, 16)


def _traffic_light(cv, cx, cy, fill, ring, focused, glyph):
    if not focused:
        fill, ring = C["tloff"], C["tloffr"]
    r = 6
    cv.pen(ring); cv.circf(cx, cy, r)
    cv.pen(fill); cv.circf(cx, cy, r - 1)
    cv.pen(C["tlgloss"]); cv.circf(cx - 1, cy - 2, 2)
    if focused:
        cv.pen(C["tlglyph"]); cv.thickness(1)
        if glyph == "x":
            cv.line(cx - 2, cy - 2, cx + 2, cy + 2)
            cv.line(cx + 2, cy - 2, cx - 2, cy + 2)
        elif glyph == "-":
            cv.line(cx - 3, cy, cx + 3, cy)
        elif glyph == "+":
            cv.line(cx - 3, cy, cx + 3, cy)
            cv.line(cx, cy - 3, cx, cy + 3)


def draw_window(cv, d, win, focused):
    x, y, w, h = win.x, win.y, win.w, win.h
    th = win.title_h
    # soft drop shadow
    cv.pen(C["shadow"]); cv.rrectf(x + 5, y + 8, w, h, 10)
    # frame (rounded) + body
    cv.pen(C["winframe"] if focused else C["winframei"])
    cv.rrectf(x, y, w, h, 9)
    cv.pen(C["win"]); cv.rectf(x + 2, y + th, w - 4, h - th - 2)
    # brushed-aluminium title bar (inset 2px so the rounded frame shows through)
    if focused:
        cv.vgrad(x + 2, y + 2, w - 4, th - 1, C["ttl0"], C["ttl1"], 8)
    else:
        cv.vgrad(x + 2, y + 2, w - 4, th - 1, C["ttl0i"], C["ttl1i"], 8)
    cv.pen(C["ttlsep"]); cv.rectf(x + 2, y + th, w - 4, 1)
    # centred title text
    txt = win.title
    maxc = max(3, (w - 130) // d.charw)
    if len(txt) > maxc:
        txt = txt[:maxc - 1] + "~"
    tx = x + w // 2 - len(txt) * d.charw // 2
    cv.pen(C["ttltxt"] if focused else C["ttltxti"])
    cv.text(tx, y + th - 7, txt)
    # traffic lights (top-left)
    (clx, cy), (mlx, _), (zlx, _) = light_centers(win)
    _traffic_light(cv, clx, cy, C["tlclose"], C["tlcloser"], focused, "x")
    _traffic_light(cv, mlx, cy, C["tlmin"], C["tlminr"], focused, "-")
    _traffic_light(cv, zlx, cy, C["tlzoom"], C["tlzoomr"], focused, "+")
    cv.thickness(1)
    # body content
    bx, by, bw, bh = win.body_rect()
    cv.clip(bx, by, bw, bh)
    if win.kind == "trash":
        draw_trash_window(cv, d, win)
    elif win.kind in APP_DRAW:
        APP_DRAW[win.kind](cv, d, win)
    cv.noclip()


