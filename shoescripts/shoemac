# =========================================================================== #
#  input parsing (ported from shoexp / slippers)
# =========================================================================== #
MOUSE_RE = re.compile(rb"\[<(\d+);(\d+);(\d+)([Mm])")
CSI_FINAL = {b"A": "up", b"B": "down", b"C": "right", b"D": "left",
             b"H": "home", b"F": "end"}
TILDE = {3: "del", 5: "pgup", 6: "pgdn", 1: "home", 4: "end"}
KEY_NAMES = ("enter", "back", "del", "tab", "up", "down", "left", "right",
             "home", "end", "pgup", "pgdn")


def parse_one(buf, i):
    b = buf[i]
    if b != 0x1b:
        if b in (0x0d, 0x0a):
            return ("enter", i + 1)
        if b in (0x7f, 0x08):
            return ("back", i + 1)
        if b == 0x09:
            return ("tab", i + 1)
        if b == 0x03:
            return ("quit", i + 1)
        return (("char", chr(b)), i + 1)
    if i + 1 >= len(buf):
        return (None, -1)
    n = buf[i + 1]
    if n == 0x5b:
        if i + 2 < len(buf) and buf[i + 2] == 0x3c:
            m = MOUSE_RE.match(buf, i + 1)
            if not m:
                return (None, -1)
            btn = int(m.group(1)); x = int(m.group(2)); y = int(m.group(3))
            return (("mouse", btn, x, y, m.group(4) == b"M"), m.end())
        j = i + 2
        while j < len(buf) and (0x30 <= buf[j] <= 0x3f):
            j += 1
        if j >= len(buf):
            return (None, -1)
        final = buf[j:j + 1]
        params = buf[i + 2:j]
        if final == b"~":
            try:
                num = int(params.split(b";")[0])
            except ValueError:
                return ("ignore", j + 1)
            return (TILDE.get(num, "ignore"), j + 1)
        if final == b"":
            return ("ignore", j + 1)
        return (CSI_FINAL.get(final, "ignore"), j + 1)
    if n == 0x4f:
        if i + 2 >= len(buf):
            return (None, -1)
        return ("ignore", i + 3)
    return ("esc", i + 1)


def parse_events(buf):
    events = []
    i = 0
    while i < len(buf):
        ev, j = parse_one(buf, i)
        if j < 0:
            break
        if ev not in (None, "ignore"):
            events.append(ev)
        i = j
    return events, buf[i:]


# =========================================================================== #
#  terminal session
# =========================================================================== #
class Term:
    def __init__(self):
        self.fd = sys.stdin.fileno()
        self.old = None

    def __enter__(self):
        self.old = termios.tcgetattr(self.fd)
        tty.setraw(self.fd)
        self.cw, self.ch = self.query_cell()
        self.w(ESC + "[?1049h" + ESC + "[2J" + ESC + "[?25l")
        # ?1003h = any-motion tracking so the Dock magnifies on hover, plus
        # SGR-pixel coordinates (?1006/?1016) that map 1:1 onto the canvas.
        self.w(ESC + "[?1003h" + ESC + "[?1006h" + ESC + "[?1016h")
        return self

    def __exit__(self, *a):
        self.w(ESC + "[?1003l" + ESC + "[?1006l" + ESC + "[?1016l")
        self.w(ESC + "[?25h" + ESC + "[?1049l")
        if self.old:
            termios.tcsetattr(self.fd, termios.TCSADRAIN, self.old)

    def w(self, s):
        os.write(self.fd, s.encode() if isinstance(s, str) else s)

    def query_cell(self):
        try:
            os.write(self.fd, (ESC + "[16t").encode())
            buf = b""
            deadline = time.monotonic() + 0.3
            while time.monotonic() < deadline:
                r, _, _ = select.select([self.fd], [], [], deadline - time.monotonic())
                if not r:
                    break
                buf += os.read(self.fd, 64)
                m = re.search(rb"\[6;(\d+);(\d+)t", buf)
                if m:
                    return int(m.group(2)), int(m.group(1))
        except OSError:
            pass
        return 8, 16


def term_cells():
    try:
        sz = os.get_terminal_size(sys.stdout.fileno())
        return sz.columns, sz.lines
    except OSError:
        return 80, 24


# =========================================================================== #
#  self-test (headless single frame)
# =========================================================================== #
def selftest():
    cw, ch = 8, 16
    cols, rows = 160, 48
    d = Desktop(cols * cw, rows * ch, cw, ch)
    for kind in ("finder", "calc", "about", "safari", "terminal"):
        if kind in WIN_SIZE:
            d.open_app(kind)
    cv = Canvas(text_mode())
    draw_wallpaper(cv, d)
    draw_desktop_icons(cv, d)
    for win in d.wins:
        draw_window(cv, d, win, win is d.top_win())
    draw_menubar(cv, d)
    draw_dock(cv, d, None)
    d.open_menu = "Window"           # exercise the dropdown path in the smoke test
    draw_menu_dropdown(cv, d)
    d.open_menu = None
    out = cv.dcs(cols, rows, C["wp1"])
    sys.stdout.write("shoemac selftest ok: %d windows, %d bytes, %d draw lines\n"
                     % (len(d.wins), len(out), len(cv.lines)))
    return 0


# =========================================================================== #
#  main
# =========================================================================== #
def main():
    if os.environ.get("SHOEMAC_SELFTEST"):
        return selftest()
    if any(a in ("-h", "--help") for a in sys.argv[1:]):
        print("shoemac - a fake Mac OS X Snow Leopard desktop in foot vector "
              "graphics.\nMouse-driven: click Dock tiles, drag windows, use the "
              "traffic lights.\nApps: Finder, Calculator, About This Mac, "
              "Safari.\nq / Ctrl-C to quit. Env: SHOEMAC_FORCE / SHOEMAC_PLAIN.")
        return 0
    if not graphics_ok():
        sys.stderr.write("shoemac needs a graphics-capable terminal (foot). "
                         "Run it inside foot, or set SHOEMAC_FORCE=1.\n")
        return 1

    resized = {"flag": True}

    def on_winch(_s, _f):
        resized["flag"] = True
    try:
        signal.signal(signal.SIGWINCH, on_winch)
    except (ValueError, OSError):
        pass

    with Term() as t:
        cw, ch = t.cw, t.ch
        cols, rows = term_cells()
        d = Desktop(cols * cw, rows * ch, cw, ch)
        buf = b""
        dirty = True
        running = [True]
        drag = {"win": None, "dx": 0, "dy": 0}
        body_drag = {"win": None}      # drag-aware app capturing the pointer
        last_click = {"t": 0.0, "tag": None}
        last_clock = ""

        def relayout():
            nonlocal cols, rows
            cols, rows = term_cells()
            d.W, d.H = cols * cw, rows * ch
            d.refit_zoomed()

        def render():
            cv = Canvas(text_mode())
            draw_wallpaper(cv, d)
            draw_desktop_icons(cv, d)
            for win in d.wins:
                if not win.minimized:
                    draw_window(cv, d, win, win is d.top_win())
            draw_menubar(cv, d)
            draw_dock(cv, d, d.dock_hover_x)
            draw_menu_dropdown(cv, d)
            t.w(cv.dcs(cols, rows, C["wp1"]))

        def in_rect(px, py, r):
            x, y, w, h = r[0], r[1], r[2], r[3]
            return x <= px < x + w and y <= py < y + h

        def is_double(tag):
            now = time.monotonic()
            hit = (now - last_click["t"] < 0.42 and last_click["tag"] == tag)
            last_click["t"] = 0.0 if hit else now
            last_click["tag"] = None if hit else tag
            return hit

        def launch(kind, path=None):
            if kind == "quit":
                running[0] = False
                return
            d.open_app(kind, path)

        def click_window_body(win, px, py, btn=0):
            if win.kind in APP_CLICK:
                return APP_CLICK[win.kind](win, px, py, d, btn)
            return True

        def do_menu_action(action):
            if action == "about":
                launch("about")
            elif action == "newfinder":
                launch("finder", os.path.expanduser("~"))
            elif action == "quit":
                running[0] = False
            elif action in ("closewin", "minimize", "hide", "zoom"):
                w = d.top_win()
                if w is None:
                    return
                if action == "closewin":
                    d.close(w)
                elif action in ("minimize", "hide"):
                    w.minimized = True
                elif action == "zoom":
                    d.toggle_zoom(w)
            elif isinstance(action, tuple) and action[0] == "focus":
                for w in d.wins:
                    if w.id == action[1]:
                        d.focus(w)
                        break

        def on_left_press(px, py):
            # global menu bar: click a title to drop its menu (toggle/switch)
            if py < d.menubar_h:
                mid = d.menubar_hit(px)
                d.open_menu = None if d.open_menu == mid else mid
                d.menu_sel = -1
                return
            # an open dropdown captures the next click (item -> action, else
            # the click just dismisses the menu)
            if d.open_menu:
                if point_in_panel(d, px, py):
                    idx = menu_row_at(d, px, py)
                    if idx is not None:
                        geom = menu_panel_geom(d)
                        it = geom[4][idx]
                        if it and it[1]:
                            do_menu_action(it[1])
                d.open_menu = None
                d.menu_sel = -1
                return
            # Dock
            if d.in_dock_zone(py):
                kind = d.dock_hit(px, py)
                if kind is not None:
                    launch(kind)
                    return
            # windows, topmost first
            win = d.win_at(px, py)
            if win is not None:
                d.focus(win)
                if in_rect(px, py, close_btn_rect(win)):
                    d.close(win)
                    return
                if in_rect(px, py, min_btn_rect(win)):
                    win.minimized = True
                    return
                if in_rect(px, py, zoom_btn_rect(win)):
                    d.toggle_zoom(win)           # maximise / restore
                    return
                if win.in_title(px, py):
                    if win.zoomed:               # dragging un-maximises
                        win.zoomed = False
                        win.restore = None
                    drag["win"] = win
                    drag["dx"] = px - win.x
                    drag["dy"] = py - win.y
                    return
                if win.kind in APP_MOUSE:
                    body_drag["win"] = win
                    APP_MOUSE[win.kind](win, "press", px, py, d, 0)
                    return
                click_window_body(win, px, py)
                return
            # desktop icons (top-right)
            ic = d.icon_at(px, py)
            if ic is not None:
                d.icon_sel = ic
                if is_double(("icon", ic)):
                    kind = DESK_ICONS[ic][0]
                    if kind == "machd":
                        launch("finder", os.path.expanduser("~"))
                    else:
                        launch(kind)
                return
            d.icon_sel = -1

        def on_right_press(px, py):
            win = d.win_at(px, py)
            if win is not None and not win.in_title(px, py) and \
                    win.kind in APP_CLICK:
                d.focus(win)
                bx, by, bw, bh = win.body_rect()
                if bx <= px < bx + bw and by <= py < by + bh:
                    click_window_body(win, px, py, 2)

        def on_motion(px, py):
            nonlocal dirty
            # while a menu is open: slide between titles, highlight items
            if d.open_menu is not None:
                if py < d.menubar_h:
                    mid = d.menubar_hit(px)
                    if mid is not None and mid != d.open_menu:
                        d.open_menu = mid
                        d.menu_sel = -1
                        dirty = True
                else:
                    sel = menu_row_at(d, px, py)
                    if sel != d.menu_sel:
                        d.menu_sel = sel if sel is not None else -1
                        dirty = True
            # track Dock hover for magnification
            new_hover = px if d.in_dock_zone(py) else None
            if new_hover != d.dock_hover_x:
                d.dock_hover_x = new_hover
                dirty = True
            if body_drag["win"] is not None:
                w = body_drag["win"]
                APP_MOUSE[w.kind](w, "drag", px, py, d, 0)
                dirty = True
                return
            if drag["win"] is not None:
                w = drag["win"]
                w.x = max(-w.w + 60, min(d.W - 40, px - drag["dx"]))
                w.y = max(d.menubar_h, min(d.H - 40, py - drag["dy"]))
                dirty = True

        def on_wheel(px, py, up):
            win = d.win_at(px, py)
            if win is None:
                return
            if win.kind in APP_WHEEL:
                APP_WHEEL[win.kind](win, px, py, up, d)

        def handle_mouse(btn, px, py, press):
            nonlocal dirty
            base = btn & ~0b11100
            if base in (64, 65):
                on_wheel(px, py, base == 64)
                dirty = True
                return
            if press and (btn & 32):
                on_motion(px, py)
                return
            if press:
                if (btn & 0b11) == 0:
                    on_left_press(px, py)
                elif (btn & 0b11) == 2:
                    on_right_press(px, py)
                dirty = True
                return
            # release
            if body_drag["win"] is not None:
                w = body_drag["win"]
                APP_MOUSE[w.kind](w, "release", px, py, d, 0)
                body_drag["win"] = None
            drag["win"] = None
            dirty = True

        while running[0]:
            if resized["flag"]:
                resized["flag"] = False
                relayout()
                dirty = True
            now_clk = time.strftime("%a %H:%M")
            if now_clk != last_clock:
                last_clock = now_clk
                dirty = True
            if dirty:
                render()
                dirty = False

            r, _, _ = select.select([t.fd], [], [], 1.0)
            if not r:
                continue
            try:
                data = os.read(t.fd, 4096)
            except OSError:
                break
            if not data:
                continue
            buf += data
            events, buf = parse_events(buf)
            for ev in events:
                if ev == "quit":
                    running[0] = False
                    break
                if isinstance(ev, tuple) and ev[0] == "mouse":
                    _, btn, x, y, press = ev
                    handle_mouse(btn, x, y, press)
                    continue
                if ev == "esc":
                    if d.open_menu is not None:
                        d.open_menu = None      # Esc closes an open menu first
                        d.menu_sel = -1
                    else:
                        w = d.top_win()
                        if w is not None:
                            d.close(w)
                    dirty = True
                    continue
                # keyboard: hand to the focused app if it captures keys,
                # else fall back to the global q/Q quit.
                key = None
                if isinstance(ev, tuple) and ev[0] == "char":
                    key = ev[1]
                elif ev in KEY_NAMES:
                    key = ev
                if key is not None:
                    w = d.top_win()
                    if (w is not None and w.kind in APP_KEY and
                            APP_KEY[w.kind](w, key, d)):
                        dirty = True
                        continue
                    if key in ("q", "Q"):
                        running[0] = False
                        break
    return 0


if __name__ == "__main__":
    try:
        sys.exit(main())
    except KeyboardInterrupt:
        sys.exit(130)
