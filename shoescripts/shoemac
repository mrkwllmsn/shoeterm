def draw_trash_window(cv, d, win):
    bx, by, bw, bh = win.body_rect()
    cv.pen(C["white"]); cv.rectf(bx, by, bw, bh)
    cx = bx + bw // 2
    draw_trash_icon(cv, cx, by + bh // 2 - 30)
    msg = "Trash is empty."
    cv.pen(C["dim"])
