# ----- menu bar ------------------------------------------------------------ #
#  The bar's clickable geometry lives in menubar_layout() so draw + hit-test
#  agree; menu_contents() supplies each dropdown's items.  An item is either
#  None (a separator) or (label, action): a falsy action draws greyed/disabled
#  (decorative), a truthy one is live and handled by do_menu_action() in main.
MENU_IDS = ("File", "Edit", "View", "Window", "Help")
MENU_ROWH = 20


def active_app_name(d):
    top = d.top_win()
    return top.title if top is not None else "Finder"


def menubar_layout(d):
    """Returns (apple_rect, items, app_name).  items = [(menu_id, label, x)],
    starting with the bold ("app") application name then the standard menus."""
    cw = d.charw
    apple = (0, 0, 26, d.menubar_h)
    name = active_app_name(d)
    if len(name) > 18:
        name = name[:17] + "~"
    items = []
    nx = 30
    items.append(("app", name, nx))
    nx += (len(name) + 2) * cw
    for m in MENU_IDS:
        items.append((m, m, nx))
        nx += (len(m) + 2) * cw
    return apple, items, name


def menu_item_rect(d, x, label):
    """Highlight / hit rectangle for a menu-bar title drawn at x."""
    cw = d.charw
    return (x - 5, 0, len(label) * cw + 10, d.menubar_h)


def draw_menubar(cv, d):
    W, mh = d.W, d.menubar_h
    cv.pen(C["menubg"]); cv.rectf(0, 0, W, mh)
    cv.pen(C["menuline"]); cv.rectf(0, mh - 1, W, 1)
    # Apple logo (drawn from primitives, ASCII-free)
    if d.open_menu == "apple":
        cv.pen(C["menuhi"]); cv.rectf(0, 0, 26, mh)
        _apple_logo(cv, 12, mh // 2, C["menuhitxt"], C["menuhi"])
    else:
        _apple_logo(cv, 12, mh // 2)
    cw = d.charw
    _apple, items, name = menubar_layout(d)
    for (mid, label, x) in items:
        bold = (mid == "app")
        if d.open_menu == mid:
            rx, ry, rw, rh = menu_item_rect(d, x, label)
            cv.pen(C["menuhi"]); cv.rectf(rx, ry, rw, rh)
            cv.pen(C["menuhitxt"])
        else:
            cv.pen(C["menuink"])
        cv.text(x, mh - 7, label)
        if bold:
            cv.text(x + 1, mh - 7, label)     # fake-bold (double strike)
    # right side: Spotlight magnifier (far right) + live clock
    spx = W - 16
    cv.pen(C["menuink"]); cv.thickness(2)
    cv.circ(spx, mh // 2 - 1, 4)
    cv.line(spx + 3, mh // 2 + 2, spx + 6, mh // 2 + 5)
    cv.thickness(1)
    clk = time.strftime("%a %H:%M")
    tx = spx - 14 - len(clk) * cw
    cv.pen(C["menuink"]); cv.text(tx, mh - 7, clk)


# ----- menu dropdowns ------------------------------------------------------- #
def menu_contents(d, mid, app):
    """The item list for an open menu.  None = separator; (label, action)
    otherwise (falsy action == greyed/decorative)."""
    if mid == "apple":
        return [("About This Mac", "about"),
                None,
                ("System Preferences...", None),
                ("App Store...", None),
                ("Force Quit...", None),
                None,
                ("Sleep", None),
                ("Restart...", None),
                ("Shut Down...", None),
                None,
                ("Log Out %s..." % d.user, "quit")]
    if mid == "app":
        return [("About %s" % app, None),
                None,
                ("Preferences...", None),
                ("Services", None),
                None,
                ("Hide %s" % app, "hide"),
                ("Hide Others", None),
                ("Show All", None),
                None,
                ("Quit %s" % app, "closewin")]
    if mid == "File":
        return [("New Finder Window", "newfinder"),
                ("New Folder", None),
                ("Open", None),
                None,
                ("Close Window", "closewin"),
                ("Save...", None),
                ("Print...", None)]
    if mid == "Edit":
        return [("Undo", None), ("Redo", None), None,
                ("Cut", None), ("Copy", None), ("Paste", None),
                ("Select All", None)]
    if mid == "View":
        return [("as Icons", None), ("as List", None), ("as Columns", None),
                None, ("Hide Toolbar", None), ("Show Path Bar", None)]
    if mid == "Window":
        items = [("Minimize", "minimize"), ("Zoom", "zoom"), None,
                 ("Bring All to Front", None)]
        wins = [w for w in d.wins if not w.minimized]
        if wins:
            items.append(None)
            top = d.top_win()
            for w in wins:
                items.append((w.title[:26], ("focus", w.id, w is top)))
        return items
    if mid == "Help":
        return [("shoemac Help", None), ("Keyboard Shortcuts", None)]
    return []


def menu_panel_geom(d):
    """Returns (x, y, w, h, items) for the open dropdown, or None."""
    mid = d.open_menu
    if not mid:
        return None
    items = menu_contents(d, mid, active_app_name(d))
    if not items:
        return None
    cw = d.charw
    labels = [it[0] for it in items if it]
    body = max((len(l) for l in labels), default=8)
    w = max(150, body * cw + 40)
    h = sum(8 if it is None else MENU_ROWH for it in items) + 8
    if mid == "apple":
        ax = 2
    else:
        ax = 2
        for (m, label, x) in menubar_layout(d)[1]:
            if m == mid:
                ax = x - 8
                break
    ax = max(2, min(ax, d.W - w - 4))
    return (ax, d.menubar_h, w, h, items)


def _menu_rows(geom):
    """Yield (idx, item, row_y, row_h) for a panel geom (shared draw/hit)."""
    _x, y, _w, _h, items = geom
    iy = y + 4
    for idx, it in enumerate(items):
        if it is None:
            yield idx, None, iy, 8
            iy += 8
        else:
            yield idx, it, iy, MENU_ROWH
            iy += MENU_ROWH


def menu_row_at(d, px, py):
    """Index of the item under (px, py) inside the open panel, or None."""
    geom = menu_panel_geom(d)
    if not geom:
        return None
    x, _y, w, _h, _items = geom
    if not (x <= px < x + w):
        return None
    for idx, it, iy, rh in _menu_rows(geom):
        if it is not None and iy <= py < iy + rh:
            return idx
    return None


def point_in_panel(d, px, py):
    geom = menu_panel_geom(d)
    if not geom:
        return False
    x, y, w, h, _items = geom
    return x <= px < x + w and y <= py < y + h


def draw_menu_dropdown(cv, d):
    geom = menu_panel_geom(d)
    if not geom:
        return
    x, y, w, h, items = geom
    cw = d.charw
    cv.pen(C["shadow"]); cv.rrectf(x + 3, y + 3, w, h, 6)
    cv.pen("#fbfbfbf7"); cv.rrectf(x, y, w, h, 6)
    cv.pen("#0000002a"); cv.rrect(x, y, w, h, 6)
    for idx, it, iy, rh in _menu_rows(geom):
        if it is None:
            cv.pen("#0000001c"); cv.rectf(x + 10, iy + 3, w - 20, 1)
            continue
        label, action = it[0], it[1]
        enabled = bool(action)
        checked = isinstance(action, tuple) and len(action) > 2 and action[2]
        hot = enabled and idx == d.menu_sel
        if hot:
            cv.vgrad(x + 3, iy, w - 6, rh, C["menuhi"], "#1456c8", 5)
            ink = C["menuhitxt"]
        else:
            ink = C["menuink"] if enabled else "#b4b4b4"
        if checked:
            cv.pen(ink); cv.circf(x + 12, iy + rh // 2, 2)
        cv.pen(ink); cv.text(x + 22, iy + rh - 6, label)


def _apple_logo(cv, cx, cy, ink=None, bg=None):
    ink = ink or C["menuink"]
    bg = bg or C["menubg"]
    cv.pen(ink)
    # body: two overlapping lobes + filler
    cv.circf(cx - 3, cy + 1, 4)
    cv.circf(cx + 3, cy + 1, 4)
    cv.rectf(cx - 4, cy - 2, 8, 5)
    # top dimple (notch between the lobes)
    cv.circf(cx, cy - 3, 2)
    # bite out of the right edge (punch with the bar background)
    cv.pen(bg); cv.circf(cx + 6, cy + 1, 3)
    # leaf
    cv.pen(ink); cv.trif(cx + 1, cy - 6, cx + 4, cy - 8, cx + 4, cy - 4)


# ----- dock ----------------------------------------------------------------- #
def draw_dock(cv, d, hover_x):
    rects = d.dock_layout(hover_x)
    if not rects:
        return
    shx, shy, shw, shh = d.dock_shelf_rect()
    # glossy translucent shelf
    cv.pen(C["dock"]); cv.rrectf(shx, shy, shw, shh, 14)
    cv.pen(C["dockline"]); cv.rectf(shx + 2, shy + 1, shw - 4, 1)
    running = set(w.kind for w in d.wins)
    for (t, kind, x, y, w, h) in rects:
        if t == "sep":
            cv.pen(C["docksep"]); cv.rectf(x + w // 2, y + 6, 1, h - 12)
            continue
        draw_dock_tile(cv, kind, x, y, w, h)
        if kind in running:
            cv.pen(C["dockdot"]); cv.circf(x + w // 2, shy + shh - 4, 2)


def draw_dock_tile(cv, kind, x, y, w, h):
    cx = x + w // 2
    if kind == "trash":
        draw_trash_icon(cv, cx, y + (h - 40) // 2)
        return
    if kind in APP_ICON48:
