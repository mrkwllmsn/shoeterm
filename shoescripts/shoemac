    cv.pen("#1c222b"); cv.rrect(x, y, w, h, 8)
    cv.pen("#ffffff33"); cv.rectf(x + 3, y + 3, w - 6, h // 2 - 3)
    ch = kind[:1].upper() if kind else "?"
    cv.pen("#ffffff"); cv.text(cx - 4, y + h // 2 + 6, ch)


