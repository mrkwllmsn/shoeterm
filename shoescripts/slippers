#!/usr/bin/env python3
# slippers - a Midnight-Commander-style dual-pane file explorer drawn
# entirely with foot's vector-graphics protocol, driven by keyboard *and* mouse.
#
#   Run it:   ./bld/debug/foot sh -c 'python3 shoescripts/slippers'
#   or, installed on PATH inside foot:   slippers [start-dir]
#
# It is the first interactive shoescript: every frame is one comma-delimited
# DCS drawing program (ESC P > g ... ESC \) printed over itself at the home
# position, exactly like memtop.sh redraws its card. Mouse clicks arrive as
# SGR-pixel reports whose pixel coordinates line up 1:1 with the canvas, so a
# click maps straight onto the drawn rows.
#
# Keys:   Up/Down PgUp/PgDn Home/End  move      Tab  switch pane
#         Enter / ->        open dir / file info  Backspace / <-  parent dir
#         F1 Help  F3 View  F5 Copy  F6 Move  F7 Mkdir  F8 Delete  F10/q Quit
# Mouse:  click a row -> select + activate its pane;  double-click a dir -> open
#         wheel -> scroll;  click the function-key bar -> fire that action
#
# v1 is navigate + view: the destructive ops (Copy/Move/Mkdir/Delete) draw a
# confirmation dialog but do nothing yet (TODO: real filesystem ops).
#
# Env:  SLIPPERS_FORCE=1  draw even if $TERM isn't foot-like
#       SLIPPERS_PLAIN=1  never draw (print a notice and exit)
#
# Stdlib only; no dependencies.

import os
import re
import select
import shutil
import signal
import stat
import sys
import termios
import time
import tty

ESC = "\033"

