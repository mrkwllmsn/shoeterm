    "page1":    "#060912",   # background gradient, bottom
    "shadow":   "#03050b",   # drop shadows
    "panel":    "#121a2e",   # panel body
    "border":   "#2b3656",   # idle panel border
    "active":   "#46d6ff",   # active accent (cyan)
    "active2":  "#7b8cff",   # secondary accent (violet)
    "hdr0":     "#26345a",   # header / bar gradient, top
    "hdr1":     "#19223c",   # header / bar gradient, bottom
    "ink":      "#eef2fb",
    "dim":      "#8a96b4",
    "faint":    "#5b678c",
    "dir":      "#6fb3ff",
    "exec":     "#4ce0a4",
    "link":     "#c79bff",
    "file":     "#c9d3e8",
    "sel0":     "#3f7bf2",   # selection gradient, top (active pane)
    "sel1":     "#23488f",   # selection gradient, bottom
    "selidle":  "#283250",   # selection bar, inactive pane
    "stripe":   "#ffffff09",  # zebra overlay (very faint)
    "accent":   "#ffc24a",   # amber highlight (F-key numbers)
