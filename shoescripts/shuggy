#  main
# --------------------------------------------------------------------------- #
HELP = """shuggy - a Buggy-Boy-style arcade racer in foot vector graphics.
Usage: shuggy            (run inside foot)
Keys:  W/up accelerate, S/down brake, A/D or left/right steer,
       R restart, Q/Esc quit. Beat the clock; laps bank time."""


def selftest():
    g = Game(8, 16, 120, 36)
    g.mode = "play"
    g.speed = MAXSPEED * 0.6
    frame = g.render()
    print("shuggy selftest OK: %d bytes, %d lines" % (len(frame), frame.count("\n")))
    return 0


def dispatch(g, ev, now):
    if ev == "up":
        g.press("accel", now)
    elif ev == "down":
        g.press("brake", now)
    elif ev == "left":
        g.press("left", now)
    elif ev == "right":
        g.press("right", now)
    elif isinstance(ev, tuple) and ev[0] == "char":
        c = ev[1]
        if c == "w":
            g.press("accel", now)
        elif c == "s":
            g.press("brake", now)
        elif c == "a":
            g.press("left", now)
        elif c == "d":
            g.press("right", now)


def main():
    if any(a in ("-h", "--help") for a in sys.argv[1:]):
        print(HELP)
        return 0
    if os.environ.get("SHUGGY_SELFTEST"):
        return selftest()
    if not graphics_ok():
        sys.stderr.write(
            "shuggy needs a graphics-capable terminal (foot). "
            "Run it inside foot, or set SHUGGY_FORCE=1.\n")
        return 1

    resized = {"flag": False}

    def on_winch(_s, _f):
        resized["flag"] = True
    try:
        signal.signal(signal.SIGWINCH, on_winch)
    except (ValueError, OSError):
        pass

    with Term() as t:
        cols, rows = term_cells()
        g = Game(t.cw, t.ch, cols, rows)
        buf = b""
        last = time.monotonic()
        running = True
        while running:
            if resized["flag"]:
                resized["flag"] = False
                cols, rows = term_cells()
                g.relayout(cols, rows)

            t.w(g.render())

            r, _, _ = select.select([t.fd], [], [], 0.033)
            now = time.monotonic()
            dt = min(0.05, now - last)
            last = now

            if r:
                try:
                    data = os.read(t.fd, 8192)
                except OSError:
                    break
                if data:
                    buf += data
                    events, buf = parse_events(buf)
                    for ev in events:
                        if ev == "quit":
                            running = False
                            break
                        if isinstance(ev, tuple) and ev[0] == "char" and ev[1] == "q":
                            running = False
                            break
                        if ev == "esc":
                            if g.mode == "play":
                                g.mode = "title"
                            else:
                                running = False
                            break
                        if g.mode != "play":
                            if isinstance(ev, tuple) and ev[0] == "char" and ev[1] == "r":
                                g.reset(); g.mode = "play"
                            elif ev in ("up", "enter") or (isinstance(ev, tuple)
                                                           and ev[0] == "char" and ev[1] == "w"):
                                if g.mode == "over":
                                    g.reset()
                                g.mode = "play"
                                g.press("accel", now)
                            continue
                        dispatch(g, ev, now)
            g.update(dt, now)
    return 0


if __name__ == "__main__":
    try:
        sys.exit(main())
    except KeyboardInterrupt:
        sys.exit(130)
