]
ICON_W, ICON_H = 80, 70


# --------------------------------------------------------------------------- #
#  the desktop / window manager
# --------------------------------------------------------------------------- #
class Desktop:
    def __init__(self, W, H, cw, ch):
        self.W, self.H, self.cw, self.ch = W, H, cw, ch
        self.charw = max(5, cw)
        self.taskbar_h = 30
        self.wins = []                 # z-order: last is topmost
        self.start_open = False
        self.icon_sel = -1
        self.cascade = 0
        self.user = os.environ.get("USER") or os.environ.get("USERNAME") or "user"
        try:
            self.host = socket.gethostname()
        except OSError:
            self.host = "localhost"

    # ----- icon hit boxes (top-left column) -------------------------------
    def icon_rect(self, i):
        x = 16
        y = 16 + i * (ICON_H + 8)
        return (x, y, ICON_W, ICON_H)

    def icon_at(self, px, py):
        for i in range(len(DESK_ICONS)):
            x, y, w, h = self.icon_rect(i)
            if x <= px < x + w and y <= py < y + h:
                return i
        return None

    # ----- start button / taskbar -----------------------------------------
    def start_rect(self):
        return (0, self.H - self.taskbar_h, 92, self.taskbar_h)

    def taskbar_btn_rect(self, idx):
        bx = 100 + idx * 164
        return (bx, self.H - self.taskbar_h + 4, 158, self.taskbar_h - 8)

    def start_menu_rect(self):
        w = 232
        head_h = 54
        h = head_h + 6
        for _kind, _label, sep in START_ITEMS:
            h += 12 if sep else 34
        h += 10                      # bottom padding
        return (0, self.H - self.taskbar_h - h, w, h)

    # ----- window management ----------------------------------------------
    def focus(self, win):
        if win in self.wins and self.wins[-1] is not win:
            self.wins.remove(win)
            self.wins.append(win)
        win.minimized = False

    def top_win(self):
        for w in reversed(self.wins):
            if not w.minimized:
                return w
        return None

    def win_at(self, px, py):
        for w in reversed(self.wins):
            if not w.minimized and w.contains(px, py):
                return w
        return None

    def open_app(self, kind, path=None):
        # focus an existing window of this kind unless it's the explorer
        # (the explorer can have several, e.g. My Documents + C:)
        if kind != "explorer":
            for w in self.wins:
                if w.kind == kind:
                    self.focus(w)
                    return w
        x = 70 + (self.cascade % 6) * 28
        y = 40 + (self.cascade % 6) * 24
        self.cascade += 1
        win = Win(kind, x, y)
        if kind == "explorer" and path:
            win.pane = Pane(path)
        self.wins.append(win)
        return win

    def close(self, win):
        if win in self.wins:
            self.wins.remove(win)


