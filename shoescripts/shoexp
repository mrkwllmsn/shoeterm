def graphics_ok():
    if os.environ.get("SHOEXP_PLAIN"):
        return False
    if os.environ.get("SHOEXP_FORCE"):
        return True
    if not sys.stdout.isatty():
        return False
    term = os.environ.get("TERM", "")
    return "foot" in term or "ghostty" in term


