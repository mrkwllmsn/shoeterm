def main():
    if os.environ.get("SHOEXP_SELFTEST"):
        return selftest()
    if any(a in ("-h", "--help") for a in sys.argv[1:]):
        print("shoexp - a fake Windows XP desktop in foot vector graphics.\n"
              "Mouse-driven: double-click icons, drag windows, use Start.\n"
              "Apps: Calculator, My Computer, Explorer, Recycle Bin,\n"
              "      Minesweeper, Notepad, Paint, Internet Explorer.\n"
              "q / Ctrl-C to quit. Env: SHOEXP_FORCE / SHOEXP_PLAIN.")
        return 0
    if not graphics_ok():
        sys.stderr.write("shoexp needs a graphics-capable terminal (foot). "
                         "Run it inside foot, or set SHOEXP_FORCE=1.\n")
        return 1

    resized = {"flag": True}

    def on_winch(_s, _f):
        resized["flag"] = True
    try:
        signal.signal(signal.SIGWINCH, on_winch)
    except (ValueError, OSError):
        pass

    with Term() as t:
        cw, ch = t.cw, t.ch
        cols, rows = term_cells()
        d = Desktop(cols * cw, rows * ch, cw, ch)
        buf = b""
        dirty = True
        running = [True]
        drag = {"win": None, "dx": 0, "dy": 0}
        body_drag = {"win": None}      # drag-aware app capturing the pointer
        last_click = {"t": 0.0, "tag": None}
        last_clock = ""

        def relayout():
            nonlocal cols, rows
            cols, rows = term_cells()
            d.W, d.H = cols * cw, rows * ch

        def render():
            cv = Canvas()
            draw_wallpaper(cv, d)
            draw_desktop_icons(cv, d)
            for win in d.wins:
                if not win.minimized:
                    draw_window(cv, d, win, win is d.top_win())
            draw_taskbar(cv, d)
            if d.start_open:
                draw_start_menu(cv, d)
            t.w(cv.dcs(cols, rows, C["sky1"]))

        def in_rect(px, py, r):
            x, y, w, h = r[0], r[1], r[2], r[3]
            return x <= px < x + w and y <= py < y + h

        def is_double(tag):
            now = time.monotonic()
            hit = (now - last_click["t"] < 0.42 and last_click["tag"] == tag)
            last_click["t"] = 0.0 if hit else now
            last_click["tag"] = None if hit else tag
            return hit

        def launch(kind, path=None):
            if kind == "quit":
                running[0] = False
                return
            d.open_app(kind, path)

        def click_start_menu(px, py):
            for x, y, w, h, kind, label in start_item_rects(d):
                if kind == "sep":
                    continue
                if in_rect(px, py, (x, y, w, h)):
                    d.start_open = False
                    if kind == "explorer":
                        launch("explorer", os.path.expanduser("~"))
                    else:
                        launch(kind)
                    return True
            return False

        def click_window_body(win, px, py, btn=0):
            # returns True if the click was consumed by the app
            if win.kind in APP_CLICK:
                return APP_CLICK[win.kind](win, px, py, d, btn)
            if win.kind == "calc":
                for label, key, col, row, span in CALC_KEYS:
                    if in_rect(px, py, calc_btn_rect(win, col, row, span)):
                        calc_press(win, key)
                        return True
                return True
            if win.kind == "mycomputer":
                for x, y, w, h, (short, label, path) in mycomputer_rows(win):
                    if in_rect(px, py, (x, y, w, h)):
                        if is_double(("drive", win.id, short)):
                            launch("explorer", path)
                        return True
                return True
            if win.kind == "explorer":
                _, _, _, _, _, row_h, list_y, list_h, visible = explorer_geom(win)
                if list_y <= py < list_y + visible * row_h:
                    r = (py - list_y) // row_h
                    idx = win.pane.top + r
                    if idx < len(win.pane.entries):
                        win.pane.sel = idx
                        e = win.pane.entries[idx]
                        if is_double(("row", win.id, idx)):
                            if e.is_dir:
                                if e.name == "..":
                                    win.pane.up()
                                else:
                                    win.pane.enter()
                return True
            return True

        def on_left_press(px, py):
            nonlocal dirty
            # start menu has priority while open
            if d.start_open:
                mr = d.start_menu_rect()
                if in_rect(px, py, mr):
                    click_start_menu(px, py)
                    return
                if not in_rect(px, py, d.start_rect()):
                    d.start_open = False
                    # fall through to let the click also act
            # start button
            if in_rect(px, py, d.start_rect()):
                d.start_open = not d.start_open
                return
            # taskbar window buttons
            if py >= d.H - d.taskbar_h:
                for idx, win in enumerate(d.wins):
                    if in_rect(px, py, d.taskbar_btn_rect(idx)):
                        if win is d.top_win() and not win.minimized:
                            win.minimized = True
                        else:
                            d.focus(win)
                        return
                return
            # windows, topmost first
            win = d.win_at(px, py)
            if win is not None:
                d.focus(win)
                if in_rect(px, py, close_btn_rect(win)):
                    d.close(win)
                    return
                if in_rect(px, py, min_btn_rect(win)):
                    win.minimized = True
                    return
                if win.in_title(px, py):
                    drag["win"] = win
                    drag["dx"] = px - win.x
                    drag["dy"] = py - win.y
                    return
                if win.kind in APP_MOUSE:
                    body_drag["win"] = win
                    APP_MOUSE[win.kind](win, "press", px, py, d, 0)
                    return
                click_window_body(win, px, py)
                return
            # desktop icons
            ic = d.icon_at(px, py)
            if ic is not None:
                d.icon_sel = ic
                if is_double(("icon", ic)):
                    kind = DESK_ICONS[ic][0]
                    if kind == "explorer":
                        launch("explorer", os.path.expanduser("~"))
                    else:
                        launch(kind)
                return
            # empty desktop
            d.icon_sel = -1
            d.start_open = False

        def on_right_press(px, py):
            # right-click is routed to the focused app's body (e.g. flagging in
            # Minesweeper); everything else ignores it.
            if d.start_open:
                return
            win = d.win_at(px, py)
            if win is not None and not win.in_title(px, py) and \
                    win.kind in APP_CLICK:
                d.focus(win)
                bx, by, bw, bh = win.body_rect()
                if bx <= px < bx + bw and by <= py < by + bh:
                    click_window_body(win, px, py, 2)

        def on_motion(px, py):
            if body_drag["win"] is not None:
                w = body_drag["win"]
                APP_MOUSE[w.kind](w, "drag", px, py, d, 0)
                return
            if drag["win"] is not None:
                w = drag["win"]
                w.x = max(-w.w + 60, min(d.W - 40, px - drag["dx"]))
                w.y = max(0, min(d.H - d.taskbar_h - 24, py - drag["dy"]))

        def on_wheel(px, py, up):
            win = d.win_at(px, py)
            if win is None:
                return
            if win.kind in APP_WHEEL:
                APP_WHEEL[win.kind](win, px, py, up, d)
                return
            if win.kind == "explorer":
                win.pane.sel += -3 if up else 3
                _, _, _, _, _, _, _, _, visible = explorer_geom(win)
                win.pane.clamp(visible)

        def handle_mouse(btn, px, py, press):
            base = btn & ~0b11100
            if base in (64, 65):
                on_wheel(px, py, base == 64)
                return
            if press and (btn & 32):
                on_motion(px, py)
                return
            if press:
                if (btn & 0b11) == 0:
                    on_left_press(px, py)
                elif (btn & 0b11) == 2:
                    on_right_press(px, py)
                return
            # release
            if body_drag["win"] is not None:
                w = body_drag["win"]
                APP_MOUSE[w.kind](w, "release", px, py, d, 0)
                body_drag["win"] = None
            drag["win"] = None

        while running[0]:
            if resized["flag"]:
                resized["flag"] = False
                relayout()
                dirty = True
            now_clk = time.strftime("%H:%M")
            if now_clk != last_clock:
                last_clock = now_clk
                dirty = True
            if dirty:
                render()
                dirty = False

            r, _, _ = select.select([t.fd], [], [], 1.0)
            if not r:
                continue
            try:
                data = os.read(t.fd, 4096)
            except OSError:
                break
            if not data:
                continue
            buf += data
            events, buf = parse_events(buf)
            for ev in events:
                if ev == "quit":
                    running[0] = False
                    break
                if isinstance(ev, tuple) and ev[0] == "mouse":
                    _, btn, x, y, press = ev
                    handle_mouse(btn, x, y, press)
                    dirty = True
                    continue
                if ev == "esc":
                    if d.start_open:
                        d.start_open = False
                    else:
                        w = d.top_win()
                        if w is not None:
                            d.close(w)
                    dirty = True
                    continue
                # keyboard: hand to the focused app if it captures keys
                # (e.g. Notepad typing), else fall back to the global q/Q quit.
                key = None
                if isinstance(ev, tuple) and ev[0] == "char":
                    key = ev[1]
                elif ev in KEY_NAMES:
                    key = ev
                if key is not None:
                    w = d.top_win()
                    if (not d.start_open and w is not None and
                            w.kind in APP_KEY and APP_KEY[w.kind](w, key, d)):
                        dirty = True
                        continue
                    if key in ("q", "Q"):
                        running[0] = False
                        break
    return 0


if __name__ == "__main__":
    try:
        sys.exit(main())
    except KeyboardInterrupt:
        sys.exit(130)
