# --------------------------------------------------------------------------- #
#  app registry  (the built-in apps above are dispatched inline; extra apps
#  live in their own shoexp_<name>.py modules and register here via make_app()).
#  An app spec is a dict; see _load_apps() for the recognised keys.
# --------------------------------------------------------------------------- #
APP_DRAW = {}     # kind -> draw(cv, d, win)
APP_CLICK = {}    # kind -> click(win, px, py, d, btn) -> bool
APP_MOUSE = {}    # kind -> mouse(win, phase, px, py, d, btn)  (drag-aware apps)
APP_KEY = {}      # kind -> key(win, key, d) -> bool
APP_WHEEL = {}    # kind -> wheel(win, px, py, up, d) -> bool
APP_ICON16 = {}   # kind -> icon16(cv, x, y)
APP_ICON48 = {}   # kind -> icon48(cv, cx, top)
APP_INIT = {}     # kind -> init(win)  (set win.state)


def register_app(spec):
    k = spec["kind"]
    WIN_SIZE[k] = tuple(spec["size"])
    WIN_TITLE[k] = spec["title"]
    APP_DRAW[k] = spec["draw"]
    if spec.get("click"):
        APP_CLICK[k] = spec["click"]
    if spec.get("mouse"):
        APP_MOUSE[k] = spec["mouse"]
    if spec.get("key"):
        APP_KEY[k] = spec["key"]
    if spec.get("wheel"):
        APP_WHEEL[k] = spec["wheel"]
    if spec.get("init"):
        APP_INIT[k] = spec["init"]
    APP_ICON16[k] = spec["icon16"]
    if spec.get("icon48"):
        APP_ICON48[k] = spec["icon48"]
    if spec.get("desktop"):
        DESK_ICONS.append((k, spec.get("desktop_label", spec["title"])))
    if spec.get("start"):
        entry = (k, spec.get("start_label", spec["title"]), False)
        # slot it above the first separator so "Turn Off Computer" stays last
        for i, (_, _, sep) in enumerate(START_ITEMS):
            if sep:
                START_ITEMS.insert(i, entry)
                break
        else:
            START_ITEMS.append(entry)


def _load_apps():
    import importlib
    for name in ("shoexp_minesweeper", "shoexp_notepad",
                 "shoexp_paint", "shoexp_ie"):
        try:
            register_app(importlib.import_module(name).make_app())
        except Exception as e:                       # noqa: BLE001
            sys.stderr.write("shoexp: skipping %s: %s\n" % (name, e))


class Win:
    _seq = 0

    def __init__(self, kind, x, y):
        Win._seq += 1
        self.id = Win._seq
        self.kind = kind
        self.x, self.y = x, y
        self.w, self.h = WIN_SIZE[kind]
        self.title = WIN_TITLE[kind]
        self.minimized = False
        self.state = {}
        if kind == "calc":
            self.state = {"cur": "0", "acc": None, "op": None, "fresh": True}
        elif kind == "explorer":
            self.pane = Pane(os.path.expanduser("~"))
            self.title = "Explorer"
        elif kind in APP_INIT:
            APP_INIT[kind](self)

    # window-local geometry helpers ----------------------------------------
    @property
    def title_h(self):
        return 26

    def body_rect(self):
        return (self.x + 4, self.y + self.title_h,
                self.w - 8, self.h - self.title_h - 4)

    def contains(self, px, py):
        return self.x <= px < self.x + self.w and self.y <= py < self.y + self.h

    def in_title(self, px, py):
        return (self.x <= px < self.x + self.w and
                self.y <= py < self.y + self.title_h)


