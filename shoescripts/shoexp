# =========================================================================== #
#  input parsing (ported from slippers)
# =========================================================================== #
MOUSE_RE = re.compile(rb"\[<(\d+);(\d+);(\d+)([Mm])")
CSI_FINAL = {b"A": "up", b"B": "down", b"C": "right", b"D": "left",
             b"H": "home", b"F": "end"}
TILDE = {3: "del", 5: "pgup", 6: "pgdn", 1: "home", 4: "end"}
# named keys an app's key handler may receive (besides single printable chars)
KEY_NAMES = ("enter", "back", "del", "tab", "up", "down", "left", "right",
             "home", "end", "pgup", "pgdn")


def parse_one(buf, i):
    b = buf[i]
    if b != 0x1b:
        if b in (0x0d, 0x0a):
            return ("enter", i + 1)
        if b in (0x7f, 0x08):
            return ("back", i + 1)
        if b == 0x09:
            return ("tab", i + 1)
        if b == 0x03:
            return ("quit", i + 1)
        return (("char", chr(b)), i + 1)
    if i + 1 >= len(buf):
        return (None, -1)
    n = buf[i + 1]
    if n == 0x5b:
        if i + 2 < len(buf) and buf[i + 2] == 0x3c:
            m = MOUSE_RE.match(buf, i + 1)
            if not m:
                return (None, -1)
            btn = int(m.group(1)); x = int(m.group(2)); y = int(m.group(3))
            return (("mouse", btn, x, y, m.group(4) == b"M"), m.end())
        j = i + 2
        while j < len(buf) and (0x30 <= buf[j] <= 0x3f):
            j += 1
        if j >= len(buf):
            return (None, -1)
        final = buf[j:j + 1]
        params = buf[i + 2:j]
        if final == b"~":
            try:
                num = int(params.split(b";")[0])
            except ValueError:
                return ("ignore", j + 1)
            return (TILDE.get(num, "ignore"), j + 1)
        if final == b"":
            return ("ignore", j + 1)
        return (CSI_FINAL.get(final, "ignore"), j + 1)
    if n == 0x4f:
        if i + 2 >= len(buf):
            return (None, -1)
        return ("ignore", i + 3)
    return ("esc", i + 1)


def parse_events(buf):
    events = []
    i = 0
    while i < len(buf):
        ev, j = parse_one(buf, i)
        if j < 0:
            break
        if ev not in (None, "ignore"):
            events.append(ev)
        i = j
    return events, buf[i:]


# =========================================================================== #
#  terminal session
# =========================================================================== #
class Term:
    def __init__(self):
        self.fd = sys.stdin.fileno()
        self.old = None

    def __enter__(self):
        self.old = termios.tcgetattr(self.fd)
        tty.setraw(self.fd)
        self.cw, self.ch = self.query_cell()
        self.w(ESC + "[?1049h" + ESC + "[2J" + ESC + "[?25l")
        self.w(ESC + "[?1002h" + ESC + "[?1006h" + ESC + "[?1016h")
        return self

    def __exit__(self, *a):
        self.w(ESC + "[?1002l" + ESC + "[?1006l" + ESC + "[?1016l")
        self.w(ESC + "[?25h" + ESC + "[?1049l")
        if self.old:
            termios.tcsetattr(self.fd, termios.TCSADRAIN, self.old)

    def w(self, s):
        os.write(self.fd, s.encode() if isinstance(s, str) else s)

    def query_cell(self):
        try:
            os.write(self.fd, (ESC + "[16t").encode())
            buf = b""
            deadline = time.monotonic() + 0.3
            while time.monotonic() < deadline:
                r, _, _ = select.select([self.fd], [], [], deadline - time.monotonic())
                if not r:
                    break
                buf += os.read(self.fd, 64)
                m = re.search(rb"\[6;(\d+);(\d+)t", buf)
                if m:
                    return int(m.group(2)), int(m.group(1))
        except OSError:
            pass
        return 8, 16


def term_cells():
    try:
        sz = os.get_terminal_size(sys.stdout.fileno())
        return sz.columns, sz.lines
    except OSError:
        return 80, 24


