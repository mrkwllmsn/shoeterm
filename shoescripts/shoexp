def draw_wallpaper(cv, d):
    W, H = d.W, d.H
    hill_top = int(H * 0.66)
    cv.vgrad(0, 0, W, hill_top + 4, C["sky0"], C["sky2"], 26)
    # soft clouds
    cv.pen(C["cloud"])
    for (cx, cy, r) in ((int(W * 0.18), int(H * 0.16), 16),
                        (int(W * 0.74), int(H * 0.10), 13),
                        (int(W * 0.60), int(H * 0.26), 11)):
        cv.circf(cx, cy, r)
        cv.circf(cx + r, cy + 3, int(r * 0.8))
        cv.circf(cx - r, cy + 4, int(r * 0.7))
        cv.rectf(cx - r, cy + 2, 2 * r, r)
    # the rolling green hill: a filled polygon with a curved crest, then a
    # vertical green gradient banded on top of it for depth
    crest = []
    n = 24
    for i in range(n + 1):
        x = W * i // n
        # two gentle humps
        import_y = hill_top + int(18 * _wave(i / n))
        crest.append((x, import_y))
    pts = []
    for (x, y) in crest:
        pts += [x, y]
    pts += [W, H, 0, H]
    cv.pen(C["hill1"])
    cv.polyf(pts)
    # banded shading under the crest (clip to below the average crest line)
    base = hill_top + 20
    cv.vgrad(0, base, W, H - base, C["hill1"], C["hill2"], 14)
    # crest highlight
    cv.thickness(3)
    cv.pen(C["hill0"])
    for i in range(n):
        x0, y0 = crest[i]
        x1, y1 = crest[i + 1]
        cv.line(x0, y0, x1, y1)
    cv.thickness(1)


def _wave(t):
    # cheap smooth 0..1..0-ish double bump without importing math at call time
    # (sin via a polynomial approximation is overkill; use a parabola pair)
    import math
    return (math.sin(t * math.pi * 2.0) * 0.5 + 0.5)


def draw_desktop_icons(cv, d):
    for i, (kind, label) in enumerate(DESK_ICONS):
        x, y, w, h = d.icon_rect(i)
        if i == d.icon_sel:
            cv.pen(C["iconsel"])
            cv.rrectf(x, y, w, h, 4)
        cx = x + w // 2
        iy = y + 8
        draw_big_icon(cv, kind, cx, iy)
        # label with a faint shadow for legibility on the wallpaper
        draw_label_centered(cv, d, cx, y + h - 14, label)


def draw_label_centered(cv, d, cx, ty, label):
    tw = len(label) * d.charw
    tx = cx - tw // 2
    tx = max(2, min(tx, d.W - tw - 2))      # keep on-screen (wide labels)
    cv.pen("#00000070")
    cv.text(tx + 1, ty + 1, label)
    cv.pen(C["iconlbl"])
    cv.text(tx, ty, label)


def draw_big_icon(cv, kind, cx, top):
    # 48px-ish icons centered on cx, starting at y=top
    if kind in APP_ICON48:
        APP_ICON48[kind](cv, cx, top)
        return
    if kind == "mycomputer":
        # CRT monitor
        cv.pen("#c9d2dc"); cv.rrectf(cx - 20, top, 40, 30, 4)
        cv.pen("#4a627e"); cv.rrectf(cx - 16, top + 3, 32, 22, 2)
        cv.vgrad(cx - 16, top + 3, 32, 22, "#2e6bd6", "#7fb0f0", 8)
        cv.pen("#aeb8c4"); cv.rectf(cx - 6, top + 30, 12, 5)
        cv.pen("#8b97a6"); cv.rrectf(cx - 14, top + 34, 28, 6, 2)
    elif kind == "explorer":
        # yellow folder with a page peeking out
        cv.pen("#fefefe"); cv.rrectf(cx - 10, top + 4, 26, 22, 2)
        cv.pen(C["diredge"]); cv.polyf([cx - 20, top + 8, cx - 8, top + 8,
                                        cx - 4, top + 4, cx - 20, top + 4])
        cv.pen(C["dir"]); cv.rrectf(cx - 20, top + 7, 40, 22, 3)
        cv.pen(lighten(C["dir"], 0.3)); cv.rectf(cx - 18, top + 9, 36, 3)
    elif kind == "recycle":
        # translucent green recycle bin
        cv.pen("#9fb6a6"); cv.polyf([cx - 14, top + 6, cx + 14, top + 6,
                                     cx + 10, top + 34, cx - 10, top + 34])
        cv.pen("#bcd3c2"); cv.polyf([cx - 12, top + 8, cx + 12, top + 8,
                                     cx + 9, top + 32, cx - 9, top + 32])
        cv.pen("#5aa05a")
        for dx in (-6, 0, 6):
            cv.rectf(cx + dx, top + 11, 2, 19)
        cv.pen("#3f8a3f"); cv.rrectf(cx - 16, top + 2, 32, 6, 2)
        # little recycle arrows on the lid
        cv.pen("#2f7d2f"); cv.arc(cx, top + 20, 7, 200, 340)


def draw_window(cv, d, win, focused):
    x, y, w, h = win.x, win.y, win.w, win.h
    th = win.title_h
    cw = d.charw
    # drop shadow
    cv.pen(C["shadow"]); cv.rrectf(x + 4, y + 5, w, h, 8)
    # frame
    cv.pen(C["winframe"] if focused else C["winframei"])
    cv.rrectf(x, y, w, h, 8)
    # title bar gradient
    if focused:
        cv.vgrad(x + 3, y + 3, w - 6, th - 2, C["ttl0"], C["ttl1"], 8)
    else:
        cv.vgrad(x + 3, y + 3, w - 6, th - 2, C["ttl0i"], C["ttl1i"], 8)
    cv.pen(lighten(C["ttl0"], 0.35) if focused else "#ffffff55")
    cv.rectf(x + 3, y + 4, w - 6, 1)
    # title icon + text
    draw_title_icon(cv, win.kind, x + 8, y + 5)
    cv.pen("#0a1b39"); cv.text(x + 28 + 1, y + 18 + 1, win.title)
    cv.pen(C["ttltxt"]); cv.text(x + 28, y + 18, win.title)
    # window controls: minimize (_) and close (X)
    cb = close_btn_rect(win)
    mb = min_btn_rect(win)
    cv.vgrad(mb[0], mb[1], mb[2], mb[3], C["ctrlhi"], C["ctrlbtn"], 5)
    cv.thickness(2); cv.pen(C["white"])
    cv.line(mb[0] + 4, mb[1] + mb[3] - 5, mb[0] + mb[2] - 5, mb[1] + mb[3] - 5)
    cv.vgrad(cb[0], cb[1], cb[2], cb[3], C["closehi"], C["closebtn"], 5)
    cv.pen(C["white"])
    cv.line(cb[0] + 5, cb[1] + 4, cb[0] + cb[2] - 5, cb[1] + cb[3] - 4)
    cv.line(cb[0] + cb[2] - 5, cb[1] + 4, cb[0] + 5, cb[1] + cb[3] - 4)
    cv.thickness(1)
    # body
    bx, by, bw, bh = win.body_rect()
    cv.pen(C["win"]); cv.rectf(bx, by, bw, bh)
    cv.clip(bx, by, bw, bh)
    if win.kind == "calc":
        draw_calc(cv, d, win)
    elif win.kind == "mycomputer":
        draw_mycomputer(cv, d, win)
    elif win.kind == "explorer":
        draw_explorer(cv, d, win)
    elif win.kind == "recycle":
        draw_recycle(cv, d, win)
    elif win.kind in APP_DRAW:
        APP_DRAW[win.kind](cv, d, win)
    cv.noclip()


def draw_title_icon(cv, kind, x, y):
    if kind in APP_ICON16:
        APP_ICON16[kind](cv, x, y)
        return
    if kind == "calc":
        cv.pen("#e8edf2"); cv.rrectf(x, y, 16, 16, 2)
        cv.pen("#2e6bd6"); cv.rectf(x + 2, y + 2, 12, 4)
        cv.pen("#9aa6b4")
        for r in range(2):
            for c in range(3):
                cv.rectf(x + 2 + c * 4, y + 8 + r * 4, 3, 3)
    elif kind == "explorer":
        cv.pen(C["dir"]); cv.rrectf(x, y + 2, 16, 12, 2)
        cv.pen(lighten(C["dir"], 0.3)); cv.rectf(x + 1, y + 3, 14, 2)
    elif kind == "mycomputer":
        cv.pen("#c9d2dc"); cv.rrectf(x, y + 1, 16, 12, 2)
        cv.vgrad(x + 2, y + 3, 12, 7, "#2e6bd6", "#7fb0f0", 4)
    elif kind == "recycle":
        cv.pen("#bcd3c2"); cv.polyf([x + 2, y + 2, x + 14, y + 2,
                                     x + 12, y + 15, x + 4, y + 15])
        cv.pen("#5aa05a"); cv.rectf(x + 7, y + 4, 2, 10)


def close_btn_rect(win):
    return (win.x + win.w - 24, win.y + 5, 18, 16)


def min_btn_rect(win):
    return (win.x + win.w - 66, win.y + 5, 18, 16)


def max_btn_rect(win):
    return (win.x + win.w - 45, win.y + 5, 18, 16)


# ----- Calculator ---------------------------------------------------------- #
CALC_KEYS = [
    # label, key, col, row, colspan
    ("C", "C", 0, 0, 1), ("+-", "neg", 1, 0, 1), ("%", "%", 2, 0, 1), ("/", "/", 3, 0, 1),
    ("7", "7", 0, 1, 1), ("8", "8", 1, 1, 1), ("9", "9", 2, 1, 1), ("*", "*", 3, 1, 1),
    ("4", "4", 0, 2, 1), ("5", "5", 1, 2, 1), ("6", "6", 2, 2, 1), ("-", "-", 3, 2, 1),
    ("1", "1", 0, 3, 1), ("2", "2", 1, 3, 1), ("3", "3", 2, 3, 1), ("+", "+", 3, 3, 1),
    ("0", "0", 0, 4, 2), (".", ".", 2, 4, 1), ("=", "=", 3, 4, 1),
]


def calc_grid(win):
    bx, by, bw, bh = win.body_rect()
    pad = 8
    disp_h = 36
    gx = bx + pad
    gy = by + pad + disp_h + 6
    gw = bw - 2 * pad
    gh = bh - pad - (gy - by)
    cols, rows = 4, 5
    cellw = gw // cols
    cellh = gh // rows
    return bx, by, bw, bh, pad, disp_h, gx, gy, cellw, cellh


def calc_btn_rect(win, col, row, span):
    _, _, _, _, _, _, gx, gy, cellw, cellh = calc_grid(win)
    x = gx + col * cellw + 2
    y = gy + row * cellh + 2
    w = cellw * span - 4
    h = cellh - 4
    return (x, y, w, h)


def draw_calc(cv, d, win):
    bx, by, bw, bh, pad, disp_h, gx, gy, cellw, cellh = calc_grid(win)
    # display (sunken)
    dx, dy, dw = bx + pad, by + pad, bw - 2 * pad
    cv.pen(C["sunkenbd"]); cv.rectf(dx - 1, dy - 1, dw + 2, disp_h + 2)
    cv.pen(C["sunken"]); cv.rectf(dx, dy, dw, disp_h)
    s = win.state["cur"]
    txt = s if len(s) <= 12 else s[:12]
    cv.pen(C["ink"])
    cv.text(dx + dw - len(txt) * d.charw - 8, dy + disp_h - 12, txt)
    # buttons
    for label, key, col, row, span in CALC_KEYS:
        x, y, w, h = calc_btn_rect(win, col, row, span)
        op = key in ("/", "*", "-", "+", "=")
        top = "#fff4d6" if key == "=" else ("#dfeaf8" if op else "#ffffff")
        bot = "#f0b43a" if key == "=" else ("#bcd2ee" if op else "#dfe4ea")
        cv.vgrad(x, y, w, h, top, bot, 5)
